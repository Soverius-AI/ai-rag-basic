{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "browser-rag-gemma4": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              { "glob": "**/*", "input": "public" },
              { "glob": "**/*", "input": "node_modules/@electric-sql/pglite/dist", "output": "/" }
            ],
            "styles": ["src/styles.css"],
            "externalDependencies": ["fs", "path", "crypto", "os", "url", "perf_hooks", "worker_threads", "module"]
          },
          "configurations": {
            "production": { "outputHashing": "all" },
            "development": { "optimization": false, "sourceMap": true }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": { "buildTarget": "browser-rag-gemma4:build:production" },
            "development": { "buildTarget": "browser-rag-gemma4:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
